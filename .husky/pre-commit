#!/bin/bash

# main ブランチでのコミットを防止
BRANCH=$(git rev-parse --abbrev-ref HEAD)

if [ "$BRANCH" = "main" ]; then
  echo "❌ エラー: main ブランチでコミットできません"
  echo ""
  echo "正しいワークフロー："
  echo "  1. git checkout -b feature/機能名"
  echo "  2. 実装・テスト"
  echo "  3. git commit -m 'feat: 説明'"
  echo "  4. git push origin feature/機能名"
  echo "  5. GitHub で PR 作成 → マージ"
  echo ""
  exit 1
fi

exit 0
